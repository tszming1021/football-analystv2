{
  "rulebook_id": "decision_iteration_rules_v1",
  "last_updated": "2026-07-08",
  "purpose": "把赛后复盘经验转成赛前最终推荐前的透明校准层。该层不替代数学模型，只做小幅、可审计的概率和比分分层修正。",
  "defaults": {
    "max_single_probability_delta": 0.08,
    "max_total_bucket_delta": 0.1,
    "top_score_conservative_ranks": 2,
    "risk_score_ranks": [
      3,
      4,
      5
    ]
  },
  "rules": {
    "worldcup_group_opening": {
      "description": "世界杯小组赛首轮更强调不败底线，强队方向保留，但深度和高总球默认降温。",
      "conditions": [
        "competition_type=world_cup",
        "stage=group",
        "round_index=1"
      ],
      "adjustments": {
        "favorite_result_delta": -0.015,
        "draw_delta": 0.025,
        "underdog_delta": -0.01,
        "handicap_cover_delta": -0.025,
        "handicap_push_delta": 0.015,
        "handicap_fail_delta": 0.01,
        "move_total_from_3plus_to_1_2": 0.04
      }
    },
    "host_opener_pressure": {
      "description": "东道主揭幕战战意强，但心理压力和开局谨慎会提高一球小胜/平局保护。",
      "conditions": [
        "is_host=true",
        "is_opening_match=true"
      ],
      "adjustments": {
        "favorite_result_delta": -0.01,
        "draw_delta": 0.01,
        "handicap_cover_delta": -0.02,
        "handicap_push_delta": 0.015,
        "handicap_fail_delta": 0.005,
        "prefer_scores": [
          "1-0",
          "2-0",
          "2-1",
          "1-1"
        ]
      }
    },
    "host_high_press_opening_upside": {
      "description": "世界杯东道主首战若具备高压、转换速度和前场终结点，早段进球会抬高上沿；Top1/Top2仍保守，Top3-Top5必须放入3-0、3-1、4-1路径。",
      "conditions": [
        "competition_type=world_cup",
        "stage=group",
        "round_index=1",
        "is_host=true",
        "tags contains host_high_press"
      ],
      "adjustments": {
        "favorite_result_delta": 0.015,
        "handicap_cover_delta": 0.02,
        "handicap_push_delta": -0.005,
        "handicap_fail_delta": -0.015,
        "move_total_from_1_2_to_4_5": 0.03,
        "prefer_risk_scores": [
          "3-0",
          "3-1",
          "4-1",
          "4-0",
          "2-1"
        ]
      }
    },
    "host_inexperienced_finishing_discount": {
      "description": "东道主有热度和场面优势，但世界杯胜场经验、终结稳定性或核心缺阵不足时，主胜降温，平局和1-1保护上调。",
      "conditions": [
        "competition_type=world_cup",
        "stage=group",
        "round_index=1",
        "is_host=true",
        "tags contains host_inexperienced_finishing_risk"
      ],
      "adjustments": {
        "favorite_result_delta": -0.025,
        "draw_delta": 0.025,
        "handicap_cover_delta": -0.02,
        "handicap_push_delta": 0.01,
        "handicap_fail_delta": 0.01,
        "prefer_scores": [
          "1-1",
          "1-0",
          "2-1",
          "0-1"
        ]
      }
    },
    "set_piece_underdog_equalizer_risk": {
      "description": "弱势方定位球威胁明显或强势方定位球防守不稳时，提高弱势方进球、平局和一球边界概率。",
      "conditions": [
        "tags contains set_piece_underdog_threat"
      ],
      "adjustments": {
        "favorite_result_delta": -0.015,
        "draw_delta": 0.015,
        "handicap_cover_delta": -0.015,
        "handicap_push_delta": 0.01,
        "handicap_fail_delta": 0.005,
        "prefer_scores": [
          "1-1",
          "2-1",
          "1-0",
          "0-1"
