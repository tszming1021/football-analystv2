        "prefer_risk_scores": [
          "1-2",
          "2-2",
          "2-1",
          "1-1"
        ]
      }
    },
    "favorite_win_not_depth": {
      "description": "强队胜面明显不等于让球方向成立；若LEG或让球层提示边界，降低深度结论。",
      "conditions": [
        "favorite_win_prob>=0.55",
        "handicap_push_or_fail>=0.52"
      ],
      "adjustments": {
        "handicap_cover_delta": -0.035,
        "handicap_push_delta": 0.02,
        "handicap_fail_delta": 0.015,
        "prefer_scores": [
          "1-0",
          "2-0"
        ]
      }
    },
    "weak_handicap_depth": {
      "description": "让球负端明显高，说明热门方赢深不成立。",
      "conditions": [
        "handicap_fail>=0.55"
      ],
      "adjustments": {
        "handicap_cover_delta": -0.03,
        "handicap_fail_delta": 0.03,
        "prefer_scores": [
          "1-1",
          "1-0",
          "0-1",
          "0-0"
        ]
      }
    },
    "weather_suppresses_tempo": {
      "description": "高温、雨战、高海拔、湿滑场地会压低节奏和连续冲刺质量。",
      "conditions": [
        "weather_suppression=true"
      ],
      "adjustments": {
        "move_total_from_3plus_to_1_2": 0.05,
