          "0-0",
          "1-0",
          "1-1",
          "2-0",
          "0-1"
        ]
      }
    },
    "material_absence_uncertain_lineup": {
      "description": "关键位置伤缺或首发不确定时，降低该队单向结果和深度置信。",
      "conditions": [
