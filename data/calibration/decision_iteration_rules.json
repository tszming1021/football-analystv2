      "adjustments": {
        "favorite_result_delta": -0.015,
        "draw_delta": 0.025,
        "underdog_delta": -0.01,
        "move_total_from_3plus_to_1_2": 0.035,
        "prefer_scores": [
          "1-1",
          "1-0",
          "0-1",
          "0-0",
          "2-1"
        ]
      }
    },
    "qimen_conflict_low_weight": {
      "description": "奇门与数据模型冲突时，只作为风险提示，小幅降低主观置信，不覆盖模型。",
